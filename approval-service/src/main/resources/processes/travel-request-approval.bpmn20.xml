<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://www.flowable.org/processdef">

    <process id="travel-request-approval" name="出差申请审批" isExecutable="true">

        <startEvent id="start" flowable:formFieldValidation="false" />

        <userTask id="managerApproval" name="经理审批"
                  flowable:candidateGroups="manager" />

        <exclusiveGateway id="gw1" default="flow_gw1_approve" />

        <userTask id="directorApproval" name="总监审批"
                  flowable:candidateGroups="director" />

        <exclusiveGateway id="gw2" default="flow_gw2_approve" />

        <exclusiveGateway id="gwDirectorCheck" default="flow_dir_skip" />

        <endEvent id="approvedEnd" name="审批通过">
            <extensionElements>
                <flowable:executionListener event="end"
                    delegateExpression="${approvalCallbackDelegate}" />
            </extensionElements>
        </endEvent>

        <endEvent id="rejectedEnd" name="审批驳回">
            <extensionElements>
                <flowable:executionListener event="end"
                    delegateExpression="${approvalCallbackDelegate}" />
            </extensionElements>
        </endEvent>

        <!-- Start → Manager -->
        <sequenceFlow id="flow_start_to_manager" sourceRef="start" targetRef="managerApproval" />

        <!-- Manager → Gateway 1 (check outcome) -->
        <sequenceFlow id="flow_mgr_to_gw1" sourceRef="managerApproval" targetRef="gw1" />

        <!-- GW1: rejected → rejectedEnd -->
        <sequenceFlow id="flow_gw1_reject" sourceRef="gw1" targetRef="rejectedEnd">
            <conditionExpression xsi:type="tFormalExpression"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${outcome == 'REJECTED'}</conditionExpression>
        </sequenceFlow>

        <!-- GW1: approved → director check gateway -->
        <sequenceFlow id="flow_gw1_approve" sourceRef="gw1" targetRef="gwDirectorCheck">
            <conditionExpression xsi:type="tFormalExpression"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${outcome == 'APPROVED'}</conditionExpression>
        </sequenceFlow>

        <!-- Director Check: needDirector=true → Director Approval -->
        <sequenceFlow id="flow_dir_yes" sourceRef="gwDirectorCheck" targetRef="directorApproval">
            <conditionExpression xsi:type="tFormalExpression"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${needDirector == true}</conditionExpression>
        </sequenceFlow>

        <!-- Director Check: needDirector=false → skip to approved end -->
        <sequenceFlow id="flow_dir_skip" sourceRef="gwDirectorCheck" targetRef="approvedEnd">
            <conditionExpression xsi:type="tFormalExpression"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${needDirector == false}</conditionExpression>
        </sequenceFlow>

        <!-- Director → Gateway 2 (check outcome) -->
        <sequenceFlow id="flow_dir_to_gw2" sourceRef="directorApproval" targetRef="gw2" />

        <!-- GW2: rejected → rejectedEnd -->
        <sequenceFlow id="flow_gw2_reject" sourceRef="gw2" targetRef="rejectedEnd">
            <conditionExpression xsi:type="tFormalExpression"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${outcome == 'REJECTED'}</conditionExpression>
        </sequenceFlow>

        <!-- GW2: approved → approvedEnd -->
        <sequenceFlow id="flow_gw2_approve" sourceRef="gw2" targetRef="approvedEnd">
            <conditionExpression xsi:type="tFormalExpression"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${outcome == 'APPROVED'}</conditionExpression>
        </sequenceFlow>

    </process>

</definitions>
